# Öffentliche Supabase-URL (kein Geheimnis)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Anon Key — nur für Client + Server mit RLS; niemals service_role hier eintragen
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Optional (Production / mehrere Node-Prozesse): gleicher Wert für alle Builds + Instanzen,
# sonst können Server-Actions mit „UnrecognizedActionError“ abbrechen (siehe Next-Doku
# failed-to-find-server-action). AES-Länge in Base64, z. B.: openssl rand 32 | base64
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
